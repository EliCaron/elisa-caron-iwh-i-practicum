doctype html
html(lang='it')
  head
    meta(charset='UTF-8')
    title= title
    link(rel='stylesheet', href='/css/style.css')
  body
    h1 Aggiungi una nuova Pizza

    form(action='/update-cobj', method='POST')
      label(for='name') Nome:
      input(type='text', id='name', name='name', required)

      label(for='ingredienti') Ingredienti:
      input(type='text', id='ingredienti', name='ingredienti', required)

      label(for='prezzo') Prezzo:
      input(type='number', id='prezzo', name='prezzo', required)

      button(type='submit') Invia

    a(href='/') Return to the homepage

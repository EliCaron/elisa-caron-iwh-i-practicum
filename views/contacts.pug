doctype html
html(lang='it')
  head
    meta(charset='UTF-8')
    title Contacts (reference)
    link(rel='stylesheet', href='/css/style.css')
  body
    h1 Contacts Table (esempio di riferimento)

    table
      thead
        tr
          th First name
          th Last name
          th Email
      tbody
        each contact in contacts
          tr
            td= contact.properties.firstname
            td= contact.properties.lastname
            td= contact.properties.email
